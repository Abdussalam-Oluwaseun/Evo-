# ── Evo Resume Tailoring API — Environment Variables ──
# Copy this file to .env and fill in your values.

# System-level Gemini API key (fallback when user doesn't provide one)
GEMINI_API_KEY=your_gemini_api_key_here

# AI model configuration (optional — defaults shown)
GEMINI_MODEL=gemini-2.0-flash
MAX_OUTPUT_TOKENS=8192
TEMPERATURE=0.7

# Set to true to enable debug mode (exposes error details in responses)
DEBUG=false

# ── Notes on Multi-Provider Support ──
# This API supports multiple AI providers. Users select their provider
# via request headers — no server-side configuration needed:
#
#   X-API-Key:      Your API key for the chosen provider
#   X-AI-Provider:  gemini | openai | anthropic | deepseek | groq | openrouter | together | mistral
#   X-AI-Model:     Optional model override (e.g. gpt-4o, claude-sonnet-4-20250514)
#
# Only GEMINI_API_KEY needs to be set here (as a fallback).
# All other provider keys are supplied per-request by the user.
